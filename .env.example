# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────
# Get a free RapidAPI key at https://rapidapi.com
# Then subscribe (free) to these two APIs:
#
#   US listings  → https://rapidapi.com/apimaker/api/realty-in-us
#   CA listings  → https://rapidapi.com/latchaw/api/canadian-real-estate-listings (or search "Canadian Real Estate" on RapidAPI)
#
# Both share the same key — just paste it below once.

VITE_RAPIDAPI_KEY=your_rapidapi_key_here
